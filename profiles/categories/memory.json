{
  "name": "memory",
  "description": "Persistence, vault, session continuity, and knowledge management",
  "marketplaces": [
    { "source": "github", "repo": "obra/superpowers-marketplace" },
    { "source": "github", "repo": "thedotmack/claude-mem" }
  ],
  "perScope": {
    "user": {
      "plugins": [
