{
  "name": "my-setup",
  "description": "Saved from existing installation",
  "mcpServers": [
    {
      "name": "context7",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "ctx7sk-redacted"
      ],
      "scope": "user"
    }
  ],
  "marketplaces": [
    {
      "source": "github",
      "repo": "anthropics/claude-plugins-official"
    },
    {
      "source": "github",
      "repo": "anthropics/skills"
    },
    {
      "source": "github",
      "repo": "jarrodwatts/claude-hud"
    },
    {
      "source": "github",
      "repo": "kokko-ng/kokko-cmds"
    },
    {
      "source": "github",
      "repo": "malston/openapi-docs-generator"
    },
    {
      "source": "github",
      "repo": "malston/vsphere-architect"
    },
    {
      "source": "github",
      "repo": "ntcoding/claude-skillz"
    },
    {
      "source": "github",
      "repo": "obra/superpowers-marketplace"
    },
    {
      "source": "github",
      "repo": "pchalasani/claude-code-tools"
    },
    {
      "source": "github",
      "repo": "thedotmack/claude-mem"
    },
    {
      "source": "github",
      "repo": "wshobson/agents"
    }
  ],
  "plugins": [
    "claude-mem@thedotmack",
    "code-simplifier@claude-plugins-official",
    "commit-commands@claude-plugins-official",
    "document-skills@anthropic-agent-skills",
    "elements-of-style@superpowers-marketplace",
    "episodic-memory@superpowers-marketplace",
    "pr-review-toolkit@claude-plugins-official",
    "superpowers-developing-for-claude-code@superpowers-marketplace",
    "superpowers@superpowers-marketplace"
  ],
  "detect": {},
  "extensions": {
    "agents": [
      "test-runner/test-runner.md"
    ],
    "commands": [
      "commit.md",
      "create-release.md",
      "make-local-issue.md",
      "recovery-prompt.md",
      "update-memory.md"
    ],
    "skills": [
      "bash",
      "golang",
      "playwright-skill",
      "pr-comments",
      "pr-review-fix",
      "session-notes",
      "the-antislop"
    ],
    "hooks": [
      "block-dangerous-commands.sh",
      "format-on-save.sh",
      "log-bash-commands.sh",
      "markdown_formatter.py",
      "protect-sensitive-files.sh"
    ],
    "rules": [
      "coding-standards.md",
      "documentation-guidelines.md",
      "naming-and-comments.md",
      "version-control.md"
    ],
    "output-styles": [
      "george-carlin.md",
      "technical-evangelist.md"
    ]
  }
}